<?xml version="1.0" encoding="utf-8"?>
<!--
  ic_launcher_background_light.xml
  Adaptive icon background — light theme
  Warm off-white #F5F2EB + subtle border grid + forest green radial glow
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base warm off-white fill -->
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"
        android:fillColor="#F5F2EB"/>

    <!-- Radial glow (soft green centre) -->
    <path
        android:pathData="M54,54 m-40,0 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0"
        android:fillColor="#1A6B3C"
        android:fillAlpha="0.08"/>

    <!-- Grid — horizontal -->
    <path android:pathData="M0,24 L108,24" android:strokeColor="#D4CFC4" android:strokeWidth="0.75"/>
    <path android:pathData="M0,48 L108,48" android:strokeColor="#D4CFC4" android:strokeWidth="0.75"/>
    <path android:pathData="M0,72 L108,72" android:strokeColor="#D4CFC4" android:strokeWidth="0.75"/>
    <path android:pathData="M0,96 L108,96" android:strokeColor="#D4CFC4" android:strokeWidth="0.75"/>

    <!-- Grid — vertical -->
    <path android:pathData="M24,0 L24,108" android:strokeColor="#D4CFC4" android:strokeWidth="0.75"/>
    <path android:pathData="M48,0 L48,108" android:strokeColor="#D4CFC4" android:strokeWidth="0.75"/>
    <path android:pathData="M72,0 L72,108" android:strokeColor="#D4CFC4" android:strokeWidth="0.75"/>
    <path android:pathData="M96,0 L96,108" android:strokeColor="#D4CFC4" android:strokeWidth="0.75"/>

</vector>
