# Release signing config. Copy to keystore.properties (gitignored) and fill in.
# Generate a keystore with:
#   keytool -genkeypair -v -keystore release.keystore -alias pass \
#     -keyalg RSA -keysize 4096 -validity 10000
# Keep release.keystore and keystore.properties OUT of version control.
storeFile=release.keystore
storePassword=CHANGEME
keyAlias=pass
keyPassword=CHANGEME
